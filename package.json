{
  "name": "bookmark-mcp",
  "version": "1.0.0",
  "description": "Local-first MCP server for AI bookmark organization, full-text search, and Chrome/CDP reading",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "bookmark-mcp": "dist/index.js",
    "ai-bookmark-mcp": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "cli": "tsx src/cli.ts",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test:smoke": "tsx test/smoke.ts && tsx test/content-smoke.ts && tsx test/browser-bridge-smoke.ts && tsx test/browser-importers-smoke.ts && tsx test/cli-smoke.ts",
    "test": "npm run build && npm run test:smoke",
    "prepublishOnly": "npm test",
    "publish:dry-run": "npm publish --dry-run"
  },
  "files": [
    "dist",
    "docs",
    "README.md",
    "SKILL.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "bookmark",
    "bookmarks",
    "ai-agent",
    "claude",
    "opencode",
    "sqlite",
    "fts5",
    "chrome-devtools-protocol"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NirussVn0/AI-Bookmark-MCP.git"
  },
  "bugs": {
    "url": "https://github.com/NirussVn0/AI-Bookmark-MCP/issues"
  },
  "homepage": "https://github.com/NirussVn0/AI-Bookmark-MCP#readme",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "better-sqlite3": "^11.8.1",
    "chrome-remote-interface": "^0.34.0",
    "pdf-parse": "^2.4.5",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/chrome-remote-interface": "^0.34.0",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
